# Ignore dotfiles and dot-directories by default (venv, caches, IDE, OS junk).
.*
!.gitignore
!.github/
!.github/**

# dot-ai generated LLM files
AGENTS.md
.AGENTS.md

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
htmlcov/

# Rust
/target/

# Compiled extension (built by maturin in CI / local dev)
python/grumpy/_core*.so
python/grumpy/_core*.pyd
python/grumpy/*.dylib
*.dSYM/

# Local benchmark / test dataset artifacts
*.gr
coverage.xml

# IDE / OS (non-dot paths)
*.swp

# Docs build output
site/
docs/generated/
